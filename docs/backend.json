
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a customer or staff member. Roles define access levels.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["traveler", "admin", "staff", "bus_owner"] },
        "walletBalance": { "type": "number" },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "Detailed record of a customer's trip booking (Hotel, Bus, or Ride).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tripName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "bookingType": { "type": "string", "enum": ["hotel", "bus", "bike", "taxi"] },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "bookingDate": { "type": "string" },
        "timestamp": { "type": "object" },
        "pickup": { "type": "string" },
        "drop": { "type": "string" },
        "seatNumber": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Financial record for wallet credits or booking payments.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "object" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "otp", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Main customer profile data."
        }
      },
      {
        "path": "/users/{userId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Private trip history for the customer."
        }
      },
      {
        "path": "/users/{userId}/transactions/{txnId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "Wallet and payment history for the customer."
        }
      },
      {
        "path": "/busBookings/{bookingId}",
        "definition": {
          "entityName": "GlobalBooking",
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Global records accessible by Admin and Captains for operations."
        }
      }
    ]
  }
}
