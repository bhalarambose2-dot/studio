{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user. Roles can be 'traveler', 'admin', 'staff', or 'bus_owner'.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["traveler", "admin", "staff", "bus_owner"] },
        "walletBalance": { "type": "number" },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "A unified booking record for any service type.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tripName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "bookingType": { "type": "string", "enum": ["hotel", "bus", "bike", "car"] },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" },
        "seatNumber": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Wallet and booking financial records.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Private booking history for a user."
        }
      },
      {
        "path": "/users/{userId}/transactions/{txnId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "User wallet transaction history."
        }
      },
      {
        "path": "/busBookings/{bookingId}",
        "definition": {
          "entityName": "BusBooking",
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Global records for bus operations."
        }
      }
    ]
  }
}