
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user. Roles can be 'traveler', 'admin', 'staff', or 'bus_owner'.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["traveler", "admin", "staff", "bus_owner"] },
        "walletBalance": { "type": "number" },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "BusBooking": {
      "title": "BusBooking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "busNumber": { "type": "string" },
        "busName": { "type": "string" },
        "seatNumber": { "type": "string" },
        "amount": { "type": "number" },
        "txnId": { "type": "string" },
        "status": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Wallet and booking financial records.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/transactions/{txnId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "User wallet transaction history."
        }
      },
      {
        "path": "/busBookings/{bookingId}",
        "definition": {
          "entityName": "BusBooking",
          "schema": { "$ref": "#/backend/entities/BusBooking" },
          "description": "Global bus bookings records."
        }
      }
    ]
  }
}
