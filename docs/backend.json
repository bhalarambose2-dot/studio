
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user. Roles can be 'traveler' or 'bus_owner'.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["traveler", "bus_owner"] },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Bus": {
      "title": "Bus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "busNumber": { "type": "string" },
        "name": { "type": "string" },
        "route": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "BusBooking": {
      "title": "BusBooking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "busId": { "type": "string" },
        "busNumber": { "type": "string" },
        "busName": { "type": "string" },
        "ownerId": { "type": "string" },
        "customerName": { "type": "string" },
        "seatNumber": { "type": "string" },
        "amount": { "type": "number" },
        "bookingDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/busBookings/{bookingId}",
        "definition": {
          "entityName": "BusBooking",
          "schema": { "$ref": "#/backend/entities/BusBooking" },
          "description": "Global bus bookings accessible by owners."
        }
      }
    ]
  }
}
