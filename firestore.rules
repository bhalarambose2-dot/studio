
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    match /users/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /busBookings/{bookingId} {
      // Travelers can create bookings
      allow create: if isSignedIn();
      // Travelers can read their own bookings
      // Owners can read bookings for their buses (simplified for prototype)
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn();
    }
    
    // Default fallback
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
