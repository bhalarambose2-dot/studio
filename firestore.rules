
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles.
     * Users can only read and write their own profile document.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      /**
       * @description Enforces access control for flight bookings subcollection.
       * Users can only manage their own bookings.
       */
      match /flightBookings/{bookingId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      
      /**
       * @description Enforces access control for hotel bookings subcollection.
       */
      match /hotelBookings/{bookingId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      /**
       * @description Enforces access control for itineraries subcollection.
       */
      match /itineraries/{itineraryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    /**
     * @description Allows public read access to destination guides.
     */
    match /destinationGuides/{guideId} {
      allow read: if true;
      allow write: if false; // Only admins (not implemented) can write guides
    }
  }
}
